-- ==================== HÀM TIỆN ÍCH ====================
function SafeNotify(title, message, duration)
    pcall(function()
        Rayfield:Notify({
            Title = title,
            Content = message,
            Duration = duration or 3,
            Image = "rbxassetid://4483345998"
        })
    end)
end

function HumanDelay(min, max)
    -- Tạo độ trễ ngẫu nhiên giống người thật
    local minDelay = min or 0.1
    local maxDelay = max or 0.5
    task.wait(math.random(minDelay * 100, maxDelay * 100) / 100)
end

function FindRemote(name)
    -- Tìm RemoteEvent an toàn
    local locations = {ReplicatedStorage, Workspace, game}
    
    for _, location in ipairs(locations) do
        local remote = location:FindFirstChild(name, true)
        if remote and remote:IsA("RemoteEvent") then
            return remote
        end
    end
    
    return nil
end

function SafeRemoteCall(name, ...)
    -- Gọi RemoteEvent an toàn với mã hóa giả lập
    if not Config.AntiBan then return false end
    
    local remote = FindRemote(name)
    if remote then
        -- Thêm độ trễ ngẫu nhiên
        HumanDelay()
        
        -- Giả lập hành vi người dùng
        local args = {...}
        
        -- Mã hóa đơn giản các tham số
        local encodedArgs = {}
        for i, arg in ipairs(args) do
            if type(arg) == "string" then
                -- Xáo trộn nhẹ string để bypass detection
                encodedArgs[i] = arg .. tostring(math.random(100, 999))
            else
                encodedArgs[i] = arg
            end
        end
        
        -- Gọi RemoteEvent với args đã mã hóa
        if #encodedArgs > 0 then
            remote:FireServer(unpack(encodedArgs))
        else
            remote:FireServer()
        end
        
        return true
    end
    return false
end

-- ==================== GHOST MODE FUNCTIONS ====================
function EnableGhostMode()
    if not LocalPlayer.Character then return end
    
    local character = LocalPlayer.Character
    local humanoid = character:FindFirstChild("Humanoid")
    local root = character:FindFirstChild("HumanoidRootPart")
    
    if not humanoid or not root then return end
    
    -- Lưu vị trí gốc
    local originalPosition = root.Position
    
    -- Hạ nhân vật xuống độ sâu -15 studs
    local undergroundPosition = Vector3.new(
        root.Position.X,
        Config.UndergroundDepth,
        root.Position.Z
    )
    
    -- Di chuyển xuống underground
    root.CFrame = CFrame.new(undergroundPosition)
    
    -- Kích hoạt No-Clip
    EnableNoClip()
    
    -- Kết nối điều khiển bay dưới lòng đất
    local flyVelocity = Instance.new("BodyVelocity")
    flyVelocity.Name = "UndergroundFly"
    flyVelocity.MaxForce = Vector3.new(100000, 100000, 100000)
    flyVelocity.Velocity = Vector3.new(0, 0, 0)
    flyVelocity.Parent = root
    
    local flyConnection
    flyConnection = RunService.Heartbeat:Connect(function()
        if not Config.GhostMode or not character:FindFirstChild("HumanoidRootPart") then
            flyConnection:Disconnect()
            if flyVelocity and flyVelocity.Parent then
                flyVelocity:Destroy()
            end
            DisableNoClip()
            return
        end
        
        -- Điều khiển bay dưới lòng đất
        local camera = Workspace.CurrentCamera
        local lookVector = camera.CFrame.LookVector
        local rightVector = camera.CFrame.RightVector
        
        local velocity = Vector3.new(0, 0, 0)
        
        -- WASD Controls
        if UserInputService:IsKeyDown(Enum.KeyCode.W) then
            velocity = velocity + (lookVector * Config.FlySpeed)
        end
        if UserInputService:IsKeyDown(Enum.KeyCode.S) then
            velocity = velocity - (lookVector * Config.FlySpeed)
        end
        if UserInputService:IsKeyDown(Enum.KeyCode.D) then
            velocity = velocity + (rightVector * Config.FlySpeed)
        end
        if UserInputService:IsKeyDown(Enum.KeyCode.A) then
            velocity = velocity - (rightVector * Config.FlySpeed)
        end
        
        -- Kiểm soát độ cao (chỉ di chuyển ngang)
        if Config.SafeAnchor then
            velocity = Vector3.new(velocity.X, 0, velocity.Z)
        else
            if UserInputService:IsKeyDown(Enum.KeyCode.Space) then
                velocity = velocity + Vector3.new(0, Config.FlySpeed, 0)
            end
            if UserInputService:IsKeyDown(Enum.KeyCode.LeftShift) then
                velocity = velocity - Vector3.new(0, Config.FlySpeed, 0)
            end
        end
        
        flyVelocity.Velocity = velocity
        humanoid.PlatformStand = true
        
        -- Giữ vị trí Y nếu SafeAnchor bật
        if Config.SafeAnchor then
            root.CFrame = CFrame.new(
                root.Position.X,
                Config.UndergroundDepth,
                root.Position.Z
            )
        end
    end)
    
    Config.Connections.GhostFly = flyConnection
    
    SafeNotify("Ghost Mode", "Đã kích hoạt chế độ dưới lòng đất", 3)
end

function DisableGhostMode()
    if Config.Connections.GhostFly then
        Config.Connections.GhostFly:Disconnect()
        Config.Connections.GhostFly = nil
    end
    
    DisableNoClip()
    
    local character = LocalPlayer.Character
    if character then
        local root = character:FindFirstChild("HumanoidRootPart")
        if root then
            local velocity = root:FindFirstChild("UndergroundFly")
            if velocity then
                velocity:Destroy()
            end
            
            -- Đưa nhân vật trở lại mặt đất
            root.CFrame = CFrame.new(root.Position.X, 5, root.Position.Z)
        end
        
        local humanoid = character:FindFirstChild("Humanoid")
        if humanoid then
            humanoid.PlatformStand = false
        end
    end
end

function EnableNoClip()
    local character = LocalPlayer.Character
    if not character then return end
    
    for _, part in ipairs(character:GetDescendants()) do
        if part:IsA("BasePart") then
            part.CanCollide = false
        end
    end
    
    -- Kết nối để duy trì No-Clip
    local noClipConnection
    noClipConnection = RunService.Stepped:Connect(function()
        if not Config.NoClip then
            noClipConnection:Disconnect()
            return
        end
        
        if character then
            for _, part in ipairs(character:GetDescendants()) do
                if part:IsA("BasePart") then
                    part.CanCollide = false
                end
            end
        end
    end)
    
    Config.Connections.NoClip = noClipConnection
end

function DisableNoClip()
    if Config.Connections.NoClip then
        Config.Connections.NoClip:Disconnect()
        Config.Connections.NoClip = nil
    end
    
    local character = LocalPlayer.Character
    if character then
        for _, part in ipairs(character:GetDescendants()) do
            if part:IsA("BasePart") then
                part.CanCollide = true
            end
        end
    end
end

-- ==================== GOD MODE FUNCTIONS ====================
function EnableGodMode()
    local character = LocalPlayer.Character
    if not character then return end
    
    local humanoid = character:FindFirstChild("Humanoid")
    if not humanoid then return end
    
    -- Lưu máu ban đầu
    Config.LastHealth = humanoid.Health
    
    -- Kết nối theo dõi máu
    local healthConnection
    healthConnection = humanoid.HealthChanged:Connect(function(newHealth)
        if not Config.GodMode then
            healthConnection:Disconnect()
            return
        end
        
        Config.LastHealth = newHealth
        
        -- Nếu máu dưới ngưỡng, kích hoạt cứu hộ
        if newHealth < Config.HealthThreshold then
            EmergencyHeal()
        end
    end)
    
    Config.Connections.GodMode = healthConnection
    
    -- Tự động hồi máu định kỳ
    task.spawn(function()
        while Config.GodMode do
            task.wait(1)
            
            if humanoid and humanoid.Health < Config.HealthThreshold then
                EmergencyHeal()
            end
        end
    end)
    
    SafeNotify("God Mode", "Đã kích hoạt chế độ bất tử", 3)
end

function EmergencyHeal()
    -- Phương pháp 1: Dùng kỹ năng hồi máu
    SafeRemoteCall("UseHealSkill")
    
    -- Phương pháp 2: Teleport đến vùng an toàn
    task.wait(0.2)
    
    local character = LocalPlayer.Character
    if character then
        local root = character:FindFirstChild("HumanoidRootPart")
        if root then
            -- Teleport đến spawn point
            local spawnPoint = Workspace:FindFirstChild("SpawnPoint") or Workspace:FindFirstChild("SafeZone")
            if spawnPoint then
                root.CFrame = spawnPoint.CFrame
            else
                -- Teleport lên cao
                root.CFrame = CFrame.new(root.Position.X, 100, root.Position.Z)
            end
        end
    end
    
    -- Phương pháp 3: Gửi yêu cầu hồi máu
    task.wait(0.3)
    SafeRemoteCall("RequestHeal")
end

function EnableSpeedBug()
    local character = LocalPlayer.Character
    if not character then return end
    
    local humanoid = character:FindFirstChild("Humanoid")
    local root = character:FindFirstChild("HumanoidRootPart")
    
    if not humanoid or not root then return end
    
    -- Sử dụng Velocity thay vì WalkSpeed để bypass detection
    local speedVelocity = Instance.new("BodyVelocity")
    speedVelocity.Name = "SpeedBugVelocity"
    speedVelocity.MaxForce = Vector3.new(100000, 0, 100000)
    speedVelocity.Velocity = Vector3.new(0, 0, 0)
    speedVelocity.Parent = root
    
    local speedConnection
    speedConnection = RunService.Heartbeat:Connect(function()
        if not Config.SpeedBug or not character:FindFirstChild("HumanoidRootPart") then
            speedConnection:Disconnect()
            if speedVelocity and speedVelocity.Parent then
                speedVelocity:Destroy()
            end
            return
        end
        
        -- Tính toán hướng di chuyển
        local moveDirection = Vector3.new(0, 0, 0)
        
        if UserInputService:IsKeyDown(Enum.KeyCode.W) then
            moveDirection = moveDirection + Vector3.new(0, 0, -1)
        end
        if UserInputService:IsKeyDown(Enum.KeyCode.S) then
            moveDirection = moveDirection + Vector3.new(0, 0, 1)
        end
        if UserInputService:IsKeyDown(Enum.KeyCode.D) then
            moveDirection = moveDirection + Vector3.new(1, 0, 0)
        end
        if UserInputService:IsKeyDown(Enum.KeyCode.A) then
            moveDirection = moveDirection + Vector3.new(-1, 0, 0)
        end
        
        -- Chuẩn hóa vector và áp dụng tốc độ
        if moveDirection.Magnitude > 0 then
            moveDirection = moveDirection.Unit
            local speed = humanoid.WalkSpeed * Config.SpeedMultiplier
            
            -- Áp dụng velocity
            speedVelocity.Velocity = moveDirection * speed
        else
            speedVelocity.Velocity = Vector3.new(0, 0, 0)
        end
    end)
    
    Config.Connections.SpeedBug = speedConnection
    
    SafeNotify("Speed Bug", "Đã kích hoạt tốc độ cao", 3)
end

function DisableSpeedBug()
    if Config.Connections.SpeedBug then
        Config.Connections.SpeedBug:Disconnect()
        Config.Connections.SpeedBug = nil
    end
    
    local character = LocalPlayer.Character
    if character then
        local root = character:FindFirstChild("HumanoidRootPart")
        if root then
            local velocity = root:FindFirstChild("SpeedBugVelocity")
            if velocity then
                velocity:Destroy()
            end
        end
    end
end

-- ==================== SECURITY FUNCTIONS ====================
function EnableAntiAFK()
    local antiAFKConnection
    antiAFKConnection = RunService.Heartbeat:Connect(function()
        if not Config.AntiAFK then
            antiAFKConnection:Disconnect()
            return
        end
        
        -- Mô phỏng nhấn phím mỗi 5 phút
        if tick() - Config.LastKeyPress > 300 then
            Config.LastKeyPress = tick()
            
            -- Giả lập nhấn phím ngẫu nhiên
            local keys = {
                Enum.KeyCode.W,
                Enum.KeyCode.A,
                Enum.KeyCode.S,
                Enum.KeyCode.D,
                Enum.KeyCode.Space
            }
            
            local randomKey = keys[math.random(1, #keys)]
            
            -- Gửi input ảo
            task.spawn(function()
                VirtualInputManager:SendKeyEvent(true, randomKey, false, nil)
                task.wait(0.1)
                VirtualInputManager:SendKeyEvent(false, randomKey, false, nil)
            end)
        end
    end)
    
    Config.Connections.AntiAFK = antiAFKConnection
end

function EnableLagFixer()
    local lagFixConnection
    lagFixConnection = RunService.Heartbeat:Connect(function()
        if not Config.LagFixer then
            lagFixConnection:Disconnect()
            return
        end
        
        local character = LocalPlayer.Character
        if not character then return end
        
        local root = character:FindFirstChild("HumanoidRootPart")
        if not root then return end
        
        -- Xóa các hiệu ứng xa
        for _, obj in ipairs(Workspace:GetDescendants()) do
            if obj:IsA("ParticleEmitter") or obj:IsA("Fire") or obj:IsA("Smoke") then
                local distance = (obj.Position - root.Position).Magnitude
                
                if distance > 50 then
                    obj:Destroy()
                end
            end
            
            -- Xóa các vật thể rác
            if obj:IsA("BasePart") and obj.Transparency > 0.8 then
                local distance = (obj.Position - root.Position).Magnitude
                
                if distance > 100 then
                    obj:Destroy()
                end
            end
        end
    end)
    
    Config.Connections.LagFixer = lagFixConnection
    
    -- Giảm chất lượng đồ họa
    if not Config.OriginalSettings.QualityLevel then
        Config.OriginalSettings.QualityLevel = settings().Rendering.QualityLevel
        Config.OriginalSettings.Shadows = Lighting.GlobalShadows
        Config.OriginalSettings.TextureQuality = settings().Rendering.MeshPartDetailLevel
    end
    
    settings().Rendering.QualityLevel = 1
    Lighting.GlobalShadows = false
    settings().Rendering.MeshPartDetailLevel = Enum.MeshPartDetailLevel.Level04
    
    SafeNotify("Lag Fixer", "Đã tối ưu FPS", 3)
end

function DisableLagFixer()
    if Config.Connections.LagFixer then
        Config.Connections.LagFixer:Disconnect()
        Config.Connections.LagFixer = nil
    end
    
    -- Khôi phục cài đặt gốc
    if Config.OriginalSettings.QualityLevel then
        settings().Rendering.QualityLevel = Config.OriginalSettings.QualityLevel
        Lighting.GlobalShadows = Config.OriginalSettings.Shadows
        settings().Rendering.MeshPartDetailLevel = Config.OriginalSettings.TextureQuality
    end
end

