function TeleportToIsland(islandName)
    local character = LocalPlayer.Character
    if not character then return end
    
    local root = character:FindFirstChild("HumanoidRootPart")
    if not root then return end
    
    -- Tìm vị trí đảo
    local targetPosition
    local islandsFolder = Workspace:FindFirstChild("Islands") or Workspace:FindFirstChild("Maps")
    
    if islandsFolder then
        local island = islandsFolder:FindFirstChild(islandName)
        if island then
            targetPosition = island:GetPivot().Position + Vector3.new(0, 5, 0)
        end
    end
    
    -- Nếu không tìm thấy, dùng vị trí mặc định
    if not targetPosition then
        local positions = {
            ["Spawn Island"] = Vector3.new(0, 50, 0),
            ["Coral Reef"] = Vector3.new(500, 50, 0),
            ["Iceberg"] = Vector3.new(1000, 50, 0),
            ["Volcano"] = Vector3.new(1500, 50, 0),
            ["Abyss"] = Vector3.new(2000, 50, 0),
            ["Golden Beach"] = Vector3.new(2500, 50, 0)
        }
        targetPosition = positions[islandName] or Vector3.new(0, 50, 0)
    end
    
    -- Teleport
    if Config.SafeMode then
        -- Dùng TweenService để teleport mượt
        local tween = TweenService:Create(root, TweenInfo.new(2), {
            CFrame = CFrame.new(targetPosition)
        })
        tween:Play()
        
        OrionLib:MakeNotification({
            Name = "Teleport",
            Content = "Đang di chuyển đến " .. islandName,
            Image = "rbxassetid://7733674079",
            Time = 2
        })
    else
        -- Teleport ngay lập tức
        root.CFrame = CFrame.new(targetPosition)
    end
end

function ReduceGraphics()
    -- Lưu cài đặt gốc
    Config.OriginalSettings = {
        QualityLevel = settings().Rendering.QualityLevel,
        Shadows = Lighting.GlobalShadows,
        TextureQuality = settings().Rendering.MeshPartDetailLevel
    }
    
    -- Giảm chất lượng
    settings().Rendering.QualityLevel = 1
    Lighting.GlobalShadows = false
    settings().Rendering.MeshPartDetailLevel = Enum.MeshPartDetailLevel.Level04
    
    -- Tắt hiệu ứng
    for _, effect in ipairs(Lighting:GetChildren()) do
        if effect:IsA("PostEffect") then
            effect.Enabled = false
        end
    end
    
    -- Giảm render distance
    local camera = Workspace.CurrentCamera
    if camera then
        camera.MaxCameraDistance = 300
    end
end

function RestoreGraphics()
    -- Khôi phục cài đặt gốc
    if Config.OriginalSettings.QualityLevel then
        settings().Rendering.QualityLevel = Config.OriginalSettings.QualityLevel
    end
    if Config.OriginalSettings.Shadows ~= nil then
        Lighting.GlobalShadows = Config.OriginalSettings.Shadows
    end
    if Config.OriginalSettings.TextureQuality then
        settings().Rendering.MeshPartDetailLevel = Config.OriginalSettings.TextureQuality
    end
    
    -- Bật lại hiệu ứng
    for _, effect in ipairs(Lighting:GetChildren()) do
        if effect:IsA("PostEffect") then
            effect.Enabled = true
        end
    end
    
    -- Khôi phục render distance
    local camera = Workspace.CurrentCamera
    if camera then
        camera.MaxCameraDistance = 10000
    end
end

function CleanWorkspace()
    local cleaned = 0
    
    -- Xóa các part trong suốt
    for _, part in ipairs(Workspace:GetChildren()) do
        if part:IsA("BasePart") and part.Transparency > 0.8 then
            part:Destroy()
            cleaned = cleaned + 1
        end
    end
    
    -- Xóa debris
    local debris = Workspace:FindFirstChild("Debris")
    if debris then
        debris:ClearAllChildren()
        cleaned = cleaned + 10
    end
    
    OrionLib:MakeNotification({
        Name = "Cleanup",
        Content = "Đã dọn dẹp " .. cleaned .. " đối tượng",
        Image = "rbxassetid://7733680425",
        Time = 3
    })
end

function EnableAntiAFK()
    local connection
    local lastPosition = Vector3.new(0, 0, 0)
    
    connection = RunService.Heartbeat:Connect(function()
        if Config.AntiAFK and LocalPlayer.Character then
            local root = LocalPlayer.Character:FindFirstChild("HumanoidRootPart")
            if root then
                -- Di chuyển nhẹ mỗi 30 giây
                if tick() % 30 < 0.1 then
                    local offset = Vector3.new(
                        math.random(-3, 3),
                        0,
                        math.random(-3, 3)
                    )
                    root.CFrame = CFrame.new(root.Position + offset)
                    
                    -- Quay lại sau 0.5 giây
                    wait(0.5)
                    root.CFrame = CFrame.new(root.Position - offset)
                end
            end
        end
    end)
    
    Config.Connections.AntiAFK = connection
end

function DisableAntiAFK()
    if Config.Connections.AntiAFK then
        Config.Connections.AntiAFK:Disconnect()
        Config.Connections.AntiAFK = nil
    end
end

