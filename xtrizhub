-- ==================== HÀM TIỆN ÍCH ====================
function SafeNotify(title, message, duration)
    pcall(function()
        Rayfield:Notify({
            Title = title,
            Content = message,
            Duration = duration or 3,
            Image = "rbxassetid://4483345998"
        })
    end)
end

function HumanDelay(min, max)
    -- Tạo độ trễ ngẫu nhiên giống người thật
    local minDelay = min or 0.1
    local maxDelay = max or 0.5
    task.wait(math.random(minDelay * 100, maxDelay * 100) / 100)
end

function FindRemote(name)
    -- Tìm RemoteEvent an toàn
    local locations = {ReplicatedStorage, Workspace, game}
    
    for _, location in ipairs(locations) do
        local remote = location:FindFirstChild(name, true)
        if remote and remote:IsA("RemoteEvent") then
            return remote
        end
    end
    
    return nil
end

function SafeRemoteCall(name, ...)
    -- Gọi RemoteEvent an toàn
    if not Config.AntiBan then return false end
    
    local remote = FindRemote(name)
    if remote then
        -- Thêm độ trễ ngẫu nhiên
        HumanDelay()
        
        -- Gọi RemoteEvent
        local args = {...}
        if #args > 0 then
            remote:FireServer(unpack(args))
        else
            remote:FireServer()
        end
        
        return true
    end
    return false
end

-- ==================== TÍNH NĂNG FARMING ====================
function StartAutoFishing()
    while Config.AutoFish do
        if not Config.AutoFish then break end
        
        -- Quăng cần
        SafeRemoteCall("CastRod")
        HumanDelay(2, 4)
        
        -- Thu cá
        SafeRemoteCall("ReelFish")
        HumanDelay(1, 2)
        
        -- Đợi ngẫu nhiên
        task.wait(math.random(Config.FishingDelay[1], Config.FishingDelay[2]))
    end
end

function StartAutoSell()
    while Config.AutoSell do
        if not Config.AutoSell then break end
        
        -- Kiểm tra inventory mỗi 30 giây
        SafeRemoteCall("SellAll")
        task.wait(30)
    end
end

function StartAutoSkills()
    while Config.AutoSkills do
        if not Config.AutoSkills then break end
        
        -- Tự động dùng skill
        local skills = {"Skill1", "Skill2", "Skill3", "Ultimate"}
        for _, skill in ipairs(skills) do
            if Config.AutoSkills then
                SafeRemoteCall("UseSkill", skill)
                HumanDelay(0.5, 1)
            end
        end
        
        task.wait(10) -- Cooldown tổng
    end
end

-- ==================== TÍNH NĂNG MOVEMENT ====================
function ToggleFly(state)
    if state then
        local bodyVelocity = Instance.new("BodyVelocity")
        bodyVelocity.Name = "FlyVelocity"
        bodyVelocity.MaxForce = Vector3.new(100000, 100000, 100000)
        bodyVelocity.Velocity = Vector3.new(0, 0, 0)
        
        local character = LocalPlayer.Character
        if character then
            local root = character:FindFirstChild("HumanoidRootPart")
            if root then
                bodyVelocity.Parent = root
                
                -- Kết nối điều khiển bay
                local connection
                connection = RunService.Heartbeat:Connect(function()
                    if not Config.FlyEnabled or not character:FindFirstChild("HumanoidRootPart") then
                        connection:Disconnect()
                        bodyVelocity:Destroy()
                        return
                    end
                    
                    local camera = Workspace.CurrentCamera
                    local lookVector = camera.CFrame.LookVector
                    local rightVector = camera.CFrame.RightVector
                    
                    local velocity = Vector3.new(0, 0, 0)
                    
                    -- Điều khiển WASD
                    if UserInputService:IsKeyDown(Enum.KeyCode.W) then
                        velocity = velocity + (lookVector * Config.FlySpeed)
                    end
                    if UserInputService:IsKeyDown(Enum.KeyCode.S) then
                        velocity = velocity - (lookVector * Config.FlySpeed)
                    end
                    if UserInputService:IsKeyDown(Enum.KeyCode.D) then
                        velocity = velocity + (rightVector * Config.FlySpeed)
                    end
                    if UserInputService:IsKeyDown(Enum.KeyCode.A) then
                        velocity = velocity - (rightVector * Config.FlySpeed)
                    end
                    if UserInputService:IsKeyDown(Enum.KeyCode.Space) then
                        velocity = velocity + Vector3.new(0, Config.FlySpeed, 0)
                    end
                    if UserInputService:IsKeyDown(Enum.KeyCode.LeftShift) then
                        velocity = velocity - Vector3.new(0, Config.FlySpeed, 0)
                    end
                    
                    bodyVelocity.Velocity = velocity
                end)
                
                Config.Connections["Fly"] = connection
            end
        end
    else
        -- Tắt fly
        if Config.Connections["Fly"] then
            Config.Connections["Fly"]:Disconnect()
            Config.Connections["Fly"] = nil
        end
        
        local character = LocalPlayer.Character
        if character then
            local root = character:FindFirstChild("HumanoidRootPart")
            if root then
                local velocity = root:FindFirstChild("FlyVelocity")
                if velocity then
                    velocity:Destroy()
                end
            end
        end
    end
end

function SetupInfiniteJump()
    local connection = UserInputService.JumpRequest:Connect(function()
        if Config.InfiniteJump and LocalPlayer.Character then
            local humanoid = LocalPlayer.Character:FindFirstChild("Humanoid")
            if humanoid then
                humanoid:ChangeState(Enum.HumanoidStateType.Jumping)
            end
        end
    end)
    
    Config.Connections["InfiniteJump"] = connection
end

-- ==================== TÍNH NĂNG GIẢM LAG ====================
function ToggleGraphicsReduction(state)
    if state then
        -- Lưu cài đặt gốc
        Config.OriginalGraphics = {
            QualityLevel = settings().Rendering.QualityLevel,
            ShadowQuality = Lighting.GlobalShadows,
            TextureQuality = settings().Rendering.MeshPartDetailLevel
        }
        
        -- Giảm chất lượng đồ họa
        settings().Rendering.QualityLevel = 1
        Lighting.GlobalShadows = false
        settings().Rendering.MeshPartDetailLevel = Enum.MeshPartDetailLevel.Level04
        
        -- Tắt hiệu ứng
        for _, effect in ipairs(Lighting:GetChildren()) do
            if effect:IsA("BloomEffect") or effect:IsA("BlurEffect") or effect:IsA("ColorCorrectionEffect") then
                effect.Enabled = false
            end
        end
        
        -- Giảm render distance
        local camera = Workspace.CurrentCamera
        if camera then
            camera.MaxCameraDistance = 500
        end
        
        SafeNotify("Giảm Lag", "Đã tối ưu đồ họa để tăng FPS", 3)
    else
        -- Khôi phục cài đặt gốc
        if Config.OriginalGraphics.QualityLevel then
            settings().Rendering.QualityLevel = Config.OriginalGraphics.QualityLevel
        end
        if Config.OriginalGraphics.ShadowQuality ~= nil then
            Lighting.GlobalShadows = Config.OriginalGraphics.ShadowQuality
        end
        if Config.OriginalGraphics.TextureQuality then
            settings().Rendering.MeshPartDetailLevel = Config.OriginalGraphics.TextureQuality
        end
        
        -- Khôi phục hiệu ứng
        for _, effect in ipairs(Lighting:GetChildren()) do
            if effect:IsA("PostEffect") then
                effect.Enabled = true
            end
        end
        
        -- Khôi phục render distance
        local camera = Workspace.CurrentCamera
        if camera then
            camera.MaxCameraDistance = 10000
        end
    end
end

-- ==================== TÍNH NĂNG ANTI-BAN ====================
function SetupAntiAFK()
    local connection
    local lastPosition = Vector3.new(0, 0, 0)
    local moveCount = 0
    
    connection = RunService.Heartbeat:Connect(function()
        if Config.AntiAFK and LocalPlayer.Character then
            local root = LocalPlayer.Character:FindFirstChild("HumanoidRootPart")
            if root then
                -- Di chuyển nhẹ mỗi 30 giây
                if tick() % 30 < 0.1 then
                    local offset = Vector3.new(
                        math.random(-2, 2),
                        0,
                        math.random(-2, 2)
                    )
                    root.CFrame = CFrame.new(root.Position + offset)
                    
                    -- Quay lại sau 0.3 giây
                    task.wait(0.3)
                    root.CFrame = CFrame.new(root.Position - offset)
                    
                    moveCount = moveCount + 1
                    if moveCount > 10 then
                        moveCount = 0
                        HumanDelay(1, 2) -- Đợi lâu hơn sau 10 lần di chuyển
                    end
                end
            end
        end
    end)
    
    Config.Connections["AntiAFK"] = connection
end

