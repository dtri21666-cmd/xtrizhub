-- Các hàm chức năng
function HumanDelay()
    -- Tạo độ trễ ngẫu nhiên giống người thật
    local minDelay = 0.1
    local maxDelay = 0.3
    task.wait(math.random(minDelay * 100, maxDelay * 100) / 100)
end

function SafeRemoteCall(RemoteName, ...)
    -- Gọi RemoteEvent an toàn với Anti-Ban
    local args = {...}
    
    -- Tìm RemoteEvent
    local remote = ReplicatedStorage:FindFirstChild(RemoteName)
    if not remote then
        remote = Workspace:FindFirstChild(RemoteName)
    end
    
    if remote and remote:IsA("RemoteEvent") then
        -- Thêm độ trễ ngẫu nhiên
        HumanDelay()
        
        -- Gọi RemoteEvent
        if #args > 0 then
            remote:FireServer(unpack(args))
        else
            remote:FireServer()
        end
        
        return true
    end
    return false
end

function AutoFishLoop()
    while AutoFishEnabled do
        -- Tự động quăng cần
        SafeRemoteCall("CastRod")
        
        -- Đợi cá cắn (giả lập)
        task.wait(math.random(2, 5))
        
        -- Thu dây khi cá cắn
        SafeRemoteCall("ReelFish")
        
        -- Đợi ngẫu nhiên trước khi câu tiếp
        task.wait(math.random(1, 3))
    end
end

function AutoSellLoop()
    while AutoSellEnabled do
        -- Kiểm tra túi đồ đầy
        SafeRemoteCall("CheckInventory")
        
        -- Nếu đầy thì bán
        SafeRemoteCall("SellAllFish")
        
        -- Chờ 10 giây trước khi kiểm tra lại
        task.wait(10)
    end
end

function AutoSkillsLoop()
    while AutoSkillsEnabled do
        local currentTime = tick()
        
        -- Duyệt qua tất cả kỹ năng
        for skillName, cooldown in pairs(SkillCooldowns) do
            if currentTime - cooldown > 30 then -- Giả sử cooldown 30 giây
                SafeRemoteCall("UseSkill", skillName)
                SkillCooldowns[skillName] = currentTime
                
                -- Chờ ngẫu nhiên giữa các kỹ năng
                task.wait(math.random(0.5, 1.5))
            end
        end
        
        task.wait(1) -- Kiểm tra mỗi giây
    end
end

function AutoFarmItemsLoop()
    while AutoFarmItemsEnabled do
        -- Tìm vật phẩm trong khu vực
        local items = Workspace:FindFirstChild("Items")
        if items then
            for _, item in pairs(items:GetChildren()) do
                if item:IsA("BasePart") and AutoFarmItemsEnabled then
                    -- Di chuyển đến vật phẩm
                    SafeTeleport(item.Position)
                    
                    -- Nhặt vật phẩm
                    SafeRemoteCall("PickupItem", item.Name)
                    
                    -- Chờ ngẫu nhiên
                    task.wait(math.random(0.3, 0.7))
                end
            end
        end
        
        task.wait(2) -- Quét lại mỗi 2 giây
    end
end

function StartFly()
    local bodyVelocity = Instance.new("BodyVelocity")
    bodyVelocity.MaxForce = Vector3.new(100000, 100000, 100000)
    bodyVelocity.Velocity = Vector3.new(0, 0, 0)
    bodyVelocity.Parent = LocalPlayer.Character:FindFirstChild("HumanoidRootPart")
    
    local flying = true
    local connection
    
    connection = game:GetService("RunService").Heartbeat:Connect(function()
        if not FlyEnabled or not LocalPlayer.Character then
            flying = false
            connection:Disconnect()
            if bodyVelocity then
                bodyVelocity:Destroy()
            end
            return
        end
        
        local humanoid = LocalPlayer.Character:FindFirstChild("Humanoid")
        local rootPart = LocalPlayer.Character:FindFirstChild("HumanoidRootPart")
        
        if humanoid and rootPart then
            -- Điều khiển bay
            local camera = Workspace.CurrentCamera
            local lookVector = camera.CFrame.LookVector
            local rightVector = camera.CFrame.RightVector
            
            local velocity = Vector3.new(0, 0, 0)
            
            -- Điều khiển bằng WASD
            if LocalPlayer:IsKeyDown(Enum.KeyCode.W) then
                velocity = velocity + (lookVector * FlySpeed)
            end
            if LocalPlayer:IsKeyDown(Enum.KeyCode.S) then
                velocity = velocity - (lookVector * FlySpeed)
            end
            if LocalPlayer:IsKeyDown(Enum.KeyCode.D) then
                velocity = velocity + (rightVector * FlySpeed)
            end
            if LocalPlayer:IsKeyDown(Enum.KeyCode.A) then
                velocity = velocity - (rightVector * FlySpeed)
            end
            if LocalPlayer:IsKeyDown(Enum.KeyCode.Space) then
                velocity = velocity + Vector3.new(0, FlySpeed, 0)
            end
            if LocalPlayer:IsKeyDown(Enum.KeyCode.LeftShift) then
                velocity = velocity - Vector3.new(0, FlySpeed, 0)
            end
            
            bodyVelocity.Velocity = velocity
            humanoid.PlatformStand = true
        end
    end)
end

function StopFly()
    if LocalPlayer.Character then
        local humanoid = LocalPlayer.Character:FindFirstChild("Humanoid")
        if humanoid then
            humanoid.PlatformStand = false
        end
    end
end

